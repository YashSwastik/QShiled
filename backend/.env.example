# QShield Backend Environment Variables
# NEVER commit .env to source control.

# Application
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key-in-production

# Database (SQLite for development)
DATABASE_URL=sqlite:///./qshield.db

# Upload limits
MAX_UPLOAD_SIZE_MB=10
ALLOWED_EXTENSIONS=.py,.js,.ts,.java,.go,.rb,.php,.c,.cpp,.h,.cs,.yaml,.yml,.json,.toml,.ini,.conf,.env,.pem,.crt,.cer,.der

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174

# Optional: future AI explanation layer (leave blank to disable)
OPENAI_API_KEY=